<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <Button
        android:id="@+id/button"
        android:layout_width="379dp"
        android:layout_height="60dp"
        android:backgroundTint="#FFA500"
        android:text="Continuar"
        android:textSize="18sp"
        app:cornerRadius="4dp"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="655dp" />

    <EditText
        android:id="@+id/editText6"
        android:layout_width="353dp"
        android:layout_height="57dp"
        android:fontFamily="arial"
        android:hint="Ex: Andressa Carneiro"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="336dp" />

    <TextView
        android:id="@+id/textView4"
        android:layout_width="300dp"
        android:layout_height="39dp"
        android:text="Data de nascimento: "
        android:textSize="28sp"
        android:fontFamily="arial"
        android:textColor="#4169E1"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="206dp" />

    <EditText
        android:layout_width="357dp"
        android:layout_height="51dp"
        android:hint="Ex: 24/02/1974"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="245dp" />

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Nome da mãe: "
        android:textSize="25sp"
        android:textColor="#4169E1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.066"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.433" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="CPF: "
        android:textSize="25sp"
        android:textColor="#4169E1"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.045"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_bias="0.159" />

    <TextView
        android:layout_width="97dp"
        android:layout_height="35dp"
        android:text="Nome: "
        android:textSize="28sp"
        android:textColor="#4169E1"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="16dp" />

    <EditText
        android:layout_width="363dp"
        android:layout_height="47dp"
        tools:layout_editor_absoluteX="16dp"
        android:hint="Ex: José Donizete Carneiro"
        tools:layout_editor_absoluteY="52dp" />

    <EditText
        android:id="@+id/editText8"
        android:layout_width="370dp"
        android:hint="Ex: 878.988.162-34"
        android:layout_height="44dp"
        tools:layout_editor_absoluteX="16dp"
        tools:layout_editor_absoluteY="146dp" />

    <Button
        android:layout_width="341dp"
        android:layout_height="138dp"
        android:backgroundTint="#F1F1F1"
        app:cornerRadius="0dp"
        tools:layout_editor_absoluteX="35dp"
        tools:layout_editor_absoluteY="430dp" />

    <Button
        android:layout_width="296dp"
        android:layout_height="56dp"
        android:backgroundTint="@color/white"
        android:text="Voltar"
        android:textColor="#FFA500"
        android:textSize="18sp"
        tools:layout_editor_absoluteX="57dp"
        tools:layout_editor_absoluteY="599dp" />
</androidx.constraintlayout.widget.ConstraintLayout>